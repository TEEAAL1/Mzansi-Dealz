{
  "rewrites": [
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/uploads/:path*", "destination": "/uploads/:path*" },
    { "source": "/shop/:path*", "destination": "/index.html" },
    { "source": "/product/:path*", "destination": "/index.html" },
    { "source": "/order-confirmation/:path*", "destination": "/index.html" },
    { "source": "/((?!.*\\..*$).*$)", "destination": "/index.html" }
  ]
}
